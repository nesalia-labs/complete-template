# Test environment for the database package.
# Copy to `.env.test` and adjust the values to your local setup.
# Vitest auto-loads `.env.test` from the package root.

# Local Postgres connection. The database must exist; create it with:
#   createdb deessejs_test
DATABASE_URL=postgres://postgres:postgres@localhost:5432/deessejs_test

# Optional: Upstash Redis for tests that need cache.
# Leave commented to skip Redis-dependent tests.
# UPSTASH_REDIS_REST_URL=http://localhost:6379
# UPSTASH_REDIS_REST_TOKEN=dev

# Log level for test runs. Keep at 'warn' to keep test output clean.
LOG_LEVEL=warn
