{
  "name": "@deessejs/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "clean": "rm -rf dist .turbo",
    "test": "vitest run",
    "test:watch": "vitest",
    "auth:generate": "npx @better-auth/cli@1.4.21 generate --config ./src/auth.ts --output ../database/src/schema/auth/index.ts --yes",
    "auth:info": "npx @better-auth/cli@1.4.21 info --config ./src/auth.ts",
    "auth:secret": "npx @better-auth/cli@1.4.21 secret"
  },
  "dependencies": {
    "@better-auth/api-key": "1.6.19",
    "@better-auth/drizzle-adapter": "1.6.19",
    "@better-auth/passkey": "1.6.11",
    "@deessejs/database": "workspace:*",
    "@deessejs/mail": "workspace:*",
    "better-auth": "1.6.19"
  },
  "devDependencies": {
    "@better-auth/test-utils": "1.6.9",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
