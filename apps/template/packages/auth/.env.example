# Copy to .env and fill with real values.

# Required for auth.ts to load. The CLI only reads the schema,
# it doesn't connect — placeholder values work for `pnpm auth:generate`.
DATABASE_URL=postgres://placeholder:placeholder@localhost:5432/placeholder

# Required for the auth instance to load (32+ chars).
# Generate with: pnpm auth:secret
BETTER_AUTH_SECRET=replace-me-with-a-32-character-secret

# Required for production (URL of the deployed app).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required for cross-subdomain cookies.
PARENT_DOMAIN=localhost

# OAuth providers (spec 1.3, 1.4). Required for sign-in.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth providers (spec 1.5, 1.6). Optional — enable in onboarding.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=
