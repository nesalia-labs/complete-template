714285714286;text-decoration:none;display:inline-block;max-width:100%;mso-padding-alt:0px;border-radius:0.375rem;background-color:rgb(0,114,145);padding-right:20px;padding-left:20px;padding-bottom:12px;padding-top:12px;text-align:center;font-size:0.875rem;font-weight:600;color:rgb(255,255,255);text-decoration-line:none" target="_blank"><span><!--[if mso]><i style="mso-font-width:500%;mso-text-raise:18" hidden>&#8202;&#8202;</i><![endif]--></span><span style="max-width:100%;display:inline-block;line-height:120%;mso-padding-alt:0px;mso-text-raise:9px">Verify email</span><span><!--[if mso]><i style="mso-font-width:500%" hidden>&#8202;&#8202;&#8203;</i><![endif]--></span></a></td></tr></tbody></table><p style="font-size:0.875rem;line-height:1.25rem;margin:0;margin-bottom:0.5rem;color:rgb(82,82,92);margin-top:0;margin-left:0;margin-right:0">If the button does not work, copy and paste this URL into your browser:</p><p style="font-size:0.75rem;line-height:1.3333333333333333;margin:0;word-break:break-all;color:rgb(107,114,128);margin-top:0;margin-bottom:0;margin-left:0;margin-right:0">https://app.deessejs.dev/verify?token=demo-verify-token-xyz789</p><p style="font-size:0.875rem;line-height:1.25rem;margin:0;margin-top:1.5rem;color:rgb(82,82,92);margin-bottom:0;margin-left:0;margin-right:0">If you did not create a DeesseJS account, you can safely ignore this email.</p></td></tr></tbody></table><hr style="width:100%;border:none;border-color:rgb(229,231,235);border-top:1px solid #eaeaea;margin:0"/><table align="center" width="100%" border="0" cellPadding="0" cellSpacing="0" role="presentation" style="padding-right:2rem;padding-left:2rem;padding-bottom:1.5rem;padding-top:1.5rem;font-size:0.75rem;line-height:1.3333333333333333;color:rgb(107,114,128)"><tbody><tr><td><p style="font-size:14px;line-height:24px;margin:0;margin-bottom:0.5rem;margin-top:0;margin-left:0;margin-right:0">The DeesseJS team</p><p style="font-size:14px;line-height:24px;margin:0;margin-top:0;margin-bottom:0;ma